   "source": [
    "# Daily Sales Summary View\n",
    "spark.sql(f\"\"\"\n",
    "CREATE OR REPLACE VIEW {gold_catalog}.v_daily_sales AS\n",
    "SELECT\n",
    "    order_date,\n",
    "    COUNT(DISTINCT order_id) AS orders,\n",
    "    ROUND(SUM(total_price),2) AS revenue\n",
    "FROM {gold_catalog}.v_sales\n",
    "GROUP BY order_date\n",
    "\"\"\")"
   ]
  }
